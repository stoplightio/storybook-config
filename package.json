{
  "name": "@stoplight/storybook-config",
  "version": "0.0.0",
  "description": "Shared storybook config for UI-Kit based project",
  "keywords": [],
  "homepage": "https://github.com/stoplightio/storybook-config",
  "bugs": "https://github.com/stoplightio/storybook-config/issues",
  "author": "Stoplight <support@stoplight.io>",
  "repository": {
    "type": "git",
    "url": "https://github.com/stoplightio/storybook-config"
  },
  "license": "Apache-2.0",
  "main": "src/index.ts",
  "files": [
    "**/*"
  ],
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "build": "NODE_OPTIONS=--openssl-legacy-provider sl-scripts build",
    "commit": "git-cz",
    "release": "NODE_OPTIONS=--openssl-legacy-provider sl-scripts release",
    "release.dryRun": "NODE_OPTIONS=--openssl-legacy-provider sl-scripts release --dry-run --debug",
    "storybook": "NODE_OPTIONS=--openssl-legacy-provider start-storybook -p 9001 -c .storybook",
    "test": "NODE_OPTIONS=--openssl-legacy-provider sl-scripts test",
    "test.prod": "NODE_OPTIONS=--openssl-legacy-provider yarn test --coverage --maxWorkers=2",
    "test.update": "NODE_OPTIONS=--openssl-legacy-provider yarn test --updateSnapshot",
    "test.watch": "NODE_OPTIONS=--openssl-legacy-provider yarn test --watch"
  },
  "peerDependencies": {
    "react": ">=16",
    "react-dom": ">=16"
  },
  "dependencies": {
    "@babel/core": "^7.8.3",
    "@storybook/addon-actions": "^5.3.8",
    "@storybook/addon-knobs": "^5.3.8",
    "@storybook/addon-links": "^5.3.8",
    "@storybook/addon-options": "^5.3.8",
    "@storybook/addons": "^5.3.8",
    "@storybook/core": "^5.3.8",
    "@storybook/react": "^5.3.8",
    "@types/node": "^13.5.0",
    "@types/react": "^16.9.19",
    "@types/react-dom": "^16.9.5",
    "@types/storybook__react": "^5.2.1",
    "autoprefixer": "^9.7.4",
    "babel-loader": "^8.0.6",
    "css-loader": "^3.4.2",
    "node-sass-package-importer": "^5.3.2",
    "postcss-import": "^12.0.1",
    "postcss-loader": "^3.0.0",
    "resolve-url-loader": "^3.1.1",
    "sass-inline-svg": "^1.2.3",
    "sass-loader": "^8.0.2",
    "style-loader": "^1.1.3",
    "ts-loader": "^6.2.1",
    "webpack": "^4.41.5"
  },
  "devDependencies": {
    "@stoplight/scripts": "^5",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.2",
    "enzyme-to-json": "^3.4.3",
    "husky": "^4.2.1",
    "jest": "^25.1.0",
    "jest-enzyme": "^7.1.2",
    "lodash": "^4.17.15",
    "react": "~16.11.0",
    "react-dom": "~16.11.0",
    "sass": "^1.97.3",
    "ts-jest": "^25.0.0",
    "typescript": "3.7.5"
  },
  "lint-staged": {
    "*.{ts,tsx}$": [
      "yarn lint.fix",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release": {
    "extends": "@stoplight/scripts/release"
  },
